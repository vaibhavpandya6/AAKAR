# Secure Environment Variables Template
# Copy this file to secure_env/{project_id}.env and fill in your credentials
#
# WARNING: This directory should be:
# 1. Outside version control (.gitignore'd)
# 2. Permissions: chmod 700 secure_env/ && chmod 600 secure_env/*.env
# 3. Never exposed in logs or API responses

# Database Credentials
DATABASE_URL=postgresql://username:password@localhost:5432/dbname
# DATABASE_URL=mysql://username:password@localhost:3306/dbname
# DATABASE_URL=mongodb://username:password@localhost:27017/dbname

# Redis
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# API Keys
# OPENAI_API_KEY=sk-...
# STRIPE_API_KEY=sk_test_...
# SENDGRID_API_KEY=SG....

# AWS Credentials
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=us-east-1

# OAuth/Auth Providers
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# JWT Secrets
# JWT_SECRET=your-super-secret-jwt-key-change-this
# JWT_REFRESH_SECRET=your-refresh-token-secret

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Application Settings
# NODE_ENV=development
# PORT=3000
# DEBUG=true
