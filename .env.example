# Environment Variables Template
# Copy this to .env and fill in your actual values

# NVIDIA API (Required for BRD-to-WBS)
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# BRD-to-WBS Pipeline Models (all use NVIDIA_API_KEY)
# Using Nemotron-3-Super-120B for all stages (optimized for 39 RPM)
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# Note: SOW and Test models now default to Nemotron (remove these lines or set to nemotron)
# NVIDIA_SOW_MODEL=nvidia/nemotron-3-super-120b-a12b
# NVIDIA_TEST_MODEL=nvidia/nemotron-3-super-120b-a12b

# Groq API (Required for other agents)
GROQ_API_KEY=gsk-your-groq-api-key-here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# Database
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/aidevplatform

# Redis
REDIS_URL=redis://localhost:6379

# Security
APP_SECRET_KEY=your-super-secret-key-change-in-production
SERVICE_TOKEN_SECRET=your-service-token-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# State Management
CHECKPOINTER=sqlite

# Workspace
WORKSPACE_BASE_PATH=./workspaces

# Sandbox
SANDBOX_IMAGE=node:18-alpine
SANDBOX_CPU_LIMIT=1000
SANDBOX_MEMORY_LIMIT=512MB
SANDBOX_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development
