# Security & Authentication
APP_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# LLM Configuration (Groq - Llama 70B)
GROQ_API_KEY=gsk-placeholder-your-groq-api-key
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# Database Configuration
# macOS/Linux (native PostgreSQL):
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/aidevplatform
# Windows (Docker Compose via docker-compose.dev.yml) — use this instead:
# POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aidevplatform

# Redis Configuration
REDIS_URL=redis://localhost:6379

# State Management
CHECKPOINTER=sqlite

# Workspace Configuration
WORKSPACE_BASE_PATH=./workspaces

# Sandbox Configuration
SANDBOX_IMAGE=node:18-alpine
SANDBOX_CPU_LIMIT=1000
SANDBOX_MEMORY_LIMIT=512MB
SANDBOX_TIMEOUT_SECONDS=30

# Logging & Environment
LOG_LEVEL=INFO
ENVIRONMENT=development

# Service Token
SERVICE_TOKEN_SECRET=your-service-token-secret-change-in-production
